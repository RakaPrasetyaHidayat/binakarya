                        Buka di Tab Baru
                    </a>
                    @endif
                </div>

                @if($isPdfPreview)
                <div class="border rounded-xl overflow-hidden transition-colors duration-300 relative"
                     :class="darkMode ? 'border-gray-700 bg-gray-800' : 'border-gray-200 bg-gray-50'">
                    {{-- Loading state --}}
                    <div x-show="!pdfLoaded && !pdfError"
                         class="absolute inset-0 flex flex-col items-center justify-center z-10 transition-colors"
                         :class="darkMode ? 'bg-gray-800' : 'bg-gray-50'"
                         style="min-height: 400px;">
                        <svg class="animate-spin w-8 h-8 mb-3 text-primary-500" fill="none" viewBox="0 0 24 24">
