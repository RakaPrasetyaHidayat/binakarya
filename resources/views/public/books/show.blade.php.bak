                        :class="pdfLoaded ? 'opacity-100' : 'opacity-0'"
                        style="height: 600px; min-height: 400px;"
                        title="Preview {{ $book->title }}"
                        x-on:load="pdfLoaded = true; pdfError = false"
                        x-on:error="pdfError = true; pdfLoaded = true"
                        loading="lazy">
                    </iframe>
                </div>
                <p class="text-xs mt-2 text-center" :class="darkMode ? 'text-gray-500' : 'text-gray-400'">
                    Jika PDF tidak muncul, coba <a href="{{ $previewSource }}" target="_blank" rel="noopener" class="underline text-primary-500 hover:text-primary-400">buka langsung di tab baru</a>.
                </p>
                @else
                <div class="border rounded-xl overflow-hidden transition-colors duration-300" :class="darkMode ? 'border-gray-700' : 'border-gray-200'">
                    <img src="{{ $previewSource }}" alt="Preview {{ $book->title }}" class="w-full h-auto">
                </div>
                @endif
            </div>
