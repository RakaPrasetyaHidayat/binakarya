    {{-- Related Books Section --}}
    @php
        $relatedBooks = \App\Models\Book::where('category_id', $book->category_id)
            ->where('id', '!=', $book->id)
            ->take(3)
            ->get();
    @endphp
    @if($relatedBooks->count() > 0)
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t transition-colors duration-300" :class="darkMode ? 'border-gray-700' : 'border-gray-200'">
