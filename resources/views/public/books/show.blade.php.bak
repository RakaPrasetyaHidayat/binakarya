                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        <span class="text-sm" :class="darkMode ? 'text-gray-400' : 'text-gray-500'">Memuat PDF...</span>
                    </div>
                    {{-- Error state --}}
                    <div x-show="pdfError"
                         class="py-10 px-6 flex flex-col items-center justify-center gap-3 text-center"
