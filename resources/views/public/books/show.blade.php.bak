                    @if($relBook->abstract)
                        <p class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm line-clamp-2">
                            {{ \Illuminate\Support\Str::limit(strip_tags($relBook->abstract), 80) }}
                        </p>
                    @else
                        <p class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm">{{ $relBook->author ?? 'Unknown' }}</p>
                    @endif
                </div>
